<UserControl x:Class="YouTubeVideoUploader.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:YouTubeVideoUploader.UI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. Google OAuth Client Secrets -->
        <GroupBox Header="Google OAuth API Credentials" Margin="0,0,0,15" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding L.ClientSecretPath}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding ClientSecretPath, UpdateSourceTrigger=PropertyChanged}" Tag="Select client_secret.json path..." ToolTip="Path to the client_secret.json credential file downloaded from the Google Developer Console." Height="26" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="{Binding L.Browse}" Command="{Binding BrowseClientSecretCommand}" ToolTip="Browse files to find client_secret.json." Grid.Column="1" Width="80" Height="26"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- 2. Language Selection -->
        <GroupBox Header="Localization" Grid.Row="1" Margin="0,0,0,15" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding L.Language}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding AvailableLanguages}" SelectedItem="{Binding SelectedLanguage}" ToolTip="Switch the user interface language instantly between English and Ukrainian." Height="26" Grid.Column="1" SelectionChanged="LanguageComboBox_SelectionChanged"/>
            </Grid>
        </GroupBox>

        <!-- 3. Presets backup and CRUD -->
        <GroupBox Header="Presets Management" Grid.Row="2" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Presets list -->
                <ListBox ItemsSource="{Binding Presets}" Grid.Row="0" Margin="0,0,0,10" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Content="{Binding DataContext.L.Delete, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        Command="{Binding DataContext.DeletePresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}" 
                                        Grid.Column="1" Width="85" Height="22" Background="#EF4444" Foreground="White" BorderThickness="0"/>
                                </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Presets Export/Import actions -->
                <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right">
                    <Button Content="{Binding L.ImportPreset}" Command="{Binding ImportPresetsCommand}" ToolTip="Import presets from a backup JSON file." Width="150" Height="28" Margin="0,0,10,0"/>
                    <Button Content="{Binding L.ExportPreset}" Command="{Binding ExportPresetsCommand}" ToolTip="Save all presets to a backup JSON file." Width="150" Height="28"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
